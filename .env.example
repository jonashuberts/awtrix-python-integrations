OPENWEATHER_API_KEY=your_owm_api_key_here

# AWTRIX Device IPs
AWTRIX_IP_WORK=192.168.1.100
AWTRIX_IP_HOME=192.168.1.101

# Locations
LOCATION_WORK="Berlin, DE"
LOCATION_HOME="Munich, DE"
