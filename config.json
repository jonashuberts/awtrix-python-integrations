{
  "interval": 300,
  "default_profile": "work",
  "profiles": [
    {
      "name": "work",
      "awtrix_ip": "http://REDACTED_IP/api/custom",
      "plugin_overrides": {
        "weather_plugin": {
          "location": "REDACTED_LOCATION"
        }
      }
    },
    {
      "name": "home",
      "awtrix_ip": "http://REDACTED_IP/api/custom",
      "plugin_overrides": {
        "weather_plugin": {
          "location": "REDACTED_LOCATION"
        }
      }
    }
  ],
  "plugins": [
    {
      "module": "youtube_plugin",
      "class": "YouTubeApp",
      "enabled": true,
      "config": {
        "api_key": "${YOUTUBE_API_KEY}",
        "channel_id": "UCGmQ7UYxfMAKYBbymrzf9-Q"
      }
    },
    {
      "module": "weather_plugin",
      "class": "WeatherApp",
      "enabled": true,
      "config": {
        "location": "REDACTED_LOCATION",
        "api_key": "${OPENWEATHER_API_KEY}"
      }
    }
  ]
}
